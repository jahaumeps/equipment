rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access to all equipment images
      allow read: if true;
      
      // Only MEPS domain users can upload images
      allow write: if request.auth != null 
                  && request.auth.token.email.matches('.*@tc\\.meps\\.tp\\.edu\\.tw');
    }
  }
}
